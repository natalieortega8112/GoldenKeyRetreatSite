# Database — works with any Postgres (Supabase, Neon, RDS, etc.)
# Use the pooled connection string for serverless functions.
POSTGRES_URL=postgres://user:password@host:6543/postgres?sslmode=require
# Optional: direct (non-pooled) connection for migrations / batch jobs.
POSTGRES_URL_NON_POOLING=postgres://user:password@host:5432/postgres?sslmode=require

# Image storage — Vercel Blob (Storage → Blob in Vercel dashboard)
BLOB_READ_WRITE_TOKEN=

# Contact form email (https://resend.com - free tier)
RESEND_API_KEY=
CONTACT_TO_EMAIL=goldenkeyretreats@gmail.com
# Optional: change once you verify your domain at Resend (e.g. "Golden Key Retreats <hello@goldenkeyretreats.org>")
CONTACT_FROM_EMAIL=Golden Key Retreats <onboarding@resend.dev>

# Admin password (override the default Golden2026$ if you ever want to change it)
ADMIN_PASSWORD=Golden2026$
ADMIN_SESSION_SECRET=
